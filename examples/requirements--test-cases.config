{
  "format": "relationship-config-v1",
  "viewers": {
    "left": {
      "displayFields": ["Requirement ID", "Title", "Priority"],
      "filterField": "Requirement ID",
      "filterValue": "",
      "sortField": "Requirement ID",
      "sortDirection": "asc",
      "exportFormat": "json"
    },
    "right": {
      "displayFields": ["Test Case ID", "Requirement ID", "Status"],
      "filterField": "Requirement ID",
      "filterValue": "",
      "sortField": "Requirement ID",
      "sortDirection": "asc",
      "exportFormat": "json"
    }
  },
  "relationship": {
    "leftMatchField": "Requirement ID",
    "rightMatchField": "Requirement ID",
    "connectionSpace": 120,
    "linkageLayout": "anchor-a",
    "showChanges": true,
    "showHardLinks": true
  },
  "files": {
    "leftFile": "requirements.csv",
    "rightFile": "test-cases.csv",
    "changesFile": "requirements--test-cases.changes"
  },
  "hotkeys": {
    "addLink": "L",
    "editRecord": "E",
    "toggleChanges": "C",
    "deleteLink": "Delete",
    "toggleHard": "H",
    "toggleSettings": "S",
    "clearSelection": "Escape",
    "menuVisible": true
  }
}
